(executable
 (name generate_plugin_checksums)
 (modules generate_plugin_checksums)
 (libraries geneweb_plugin))

(rule
 (target plugin_checksums.ml)
 (deps
  (glob_files_rec ../../plugins/*))
 (action
  (with-stdout-to
   %{target}
   (run ./generate_plugin_checksums.exe %{project_root}/plugins))))

(generate_sites_module
 (module geneweb_sites)
