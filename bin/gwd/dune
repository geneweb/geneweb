(generate_sites_module
 (module sites)
 (sites geneweb)
 (plugins
  (geneweb plugins)))

(library
 (public_name geneweb.register)
 (name geneweb_register)
 (modules registration)
 (libraries geneweb geneweb_compat))

(library
 (public_name geneweb.gwd_lib)
 (name gwd_lib)
 (libraries
  geneweb
  geneweb_http
  geneweb_register
  dune-site
  dune-site.plugins
  cmdliner)
 (modules base64 request sites cmd cmd_legacy robot))

(executable
 (package geneweb)
 (name gwd)
 (public_name gwd)
 (flags
  (:standard
   (:include ../flags.dune)))
 (libraries
  dynlink
  geneweb
  geneweb_http
  geneweb_register
  gwd_lib
  logs
  logs-syslog
  logs-syslog.unix
  fmt
  fmt.tty
  str
  unix
  uri)
 (modules gwd))

(rule
 (target
  (dir cmdliner-support))
 (deps gwd.exe)
 (action
  (ignore-stdout
   (run cmdliner install tool-support ./gwd.exe:gwd cmdliner-support))))

(rule
 (deps
  (:input cmdliner-support))
 (action
  (with-stdout-to
   cmdliner-support-files.inc
   (run ../generate_cmdliner_rules.exe %{input}))))

(install
 (package geneweb)
 (section share_root)
 (files
  (include ./cmdliner-support-files.inc)))
