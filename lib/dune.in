(dirs :standard \ %%%DUNE_DIRS_EXCLUDE%%%)

(rule
  (target version.ml)
  (action
    (with-stdout-to %{target}
      (system "sh ./version.sh"))))

(library
 (name geneweb)
 (public_name geneweb)
 (synopsis "GeneWeb library")
 (preprocess (action (run %{bin:cppo} %%%CPPO_D%%% -V OCAML:%{ocaml_version} %{input-file})))
 (libraries unix
            str
            stdlib-shims
            camlp-streams
            geneweb_core
            geneweb_def
            geneweb_db
            geneweb_sosa
            geneweb_util
            geneweb_templ
            yojson
            markup
            re
            uucp
            uri
            wserver
            digestif))
